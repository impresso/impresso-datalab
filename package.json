{
  "name": "bustling-bar",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run createfontscss && npm run cp-search-dev && astro dev",
    "start": "astro dev",
    "check": "astro check",
    "build": "npm run createfontscss && astro check &&  astro build && npm run build-search",
    "preview": "astro preview",
    "astro": "astro",
    "createfontscss": "node ./createfontscss.js",
    "storybook": "npm run createfontscss && storybook dev -p 6006",
    "build-storybook": "storybook build",
    "updatenotebooks": "tsx ./scripts/updateNotebooks.ts",
    "build-search": "pagefind --site dist",
    "cp-search-dev": "node -e \"const fs = require('fs'); if (fs.existsSync('./dist/pagefind')) { fs.cpSync('./dist/pagefind', './public/pagefind', { recursive: true }); }\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky",
    "update-data-release-cards": "tsx ./scripts/updateDataReleaseCards.ts",
    "update-datasets": "tsx ./scripts/updateDatasets.ts",
    "update-notebooks": "tsx ./scripts/updateNotebooks.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^4.4.2",
    "@astrojs/vue": "^5.1.4",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-bibtex": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@codemirror/lang-python": "^6.1.6",
    "@feathersjs/authentication-client": "^5.0.30",
    "@feathersjs/errors": "^5.0.30",
    "@feathersjs/feathers": "^5.0.30",
    "@feathersjs/socketio-client": "^5.0.30",
    "@iconoir/vue": "^7.11.0",
    "@react-spring/web": "^9.7.5",
    "@tanstack/react-query": "^5.55.4",
    "@types/react-bootstrap": "^0.32.37",
    "@uiw/codemirror-theme-duotone": "^4.23.2",
    "@uiw/codemirror-theme-material": "^4.23.5",
    "@uiw/codemirror-theme-nord": "^4.23.1",
    "@uiw/codemirror-themes": "^4.23.5",
    "@uiw/react-codemirror": "^4.23.1",
    "astro": "^5.18.0",
    "axios": "^1.7.7",
    "bootstrap": "^5.3.8",
    "boring-avatars": "^1.11.2",
    "github-slugger": "^2.0.0",
    "iconoir-react": "^7.9.0",
    "impresso-jscommons": "github:impresso/impresso-jscommons#v1.4.1",
    "impresso-ui-components": "github:impresso/impresso-ui-components#develop",
    "luxon": "^3.5.0",
    "marked": "^14.1.2",
    "pagefind": "^1.4.0",
    "react": "^18.3.0",
    "react-bootstrap": "^2.10.4",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5",
    "typescript": "^5.5.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^2.0.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.5",
    "@storybook/blocks": "^8.6.14",
    "@storybook/builder-vite": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "^8.6.14",
    "@types/luxon": "^3.4.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.0.18",
    "arg": "^5.0.2",
    "dotenv": "^16.4.5",
    "http-proxy-middleware": "^3.0.2",
    "husky": "^9.1.7",
    "msw": "^2.6.6",
    "msw-storybook-addon": "^2.0.3",
    "storybook": "^8.6.14",
    "tsx": "^4.21.0",
    "vite": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
