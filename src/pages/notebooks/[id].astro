---
import NotebookModal from '../../components/NotebookModal';
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content';
import { getRecursivelyEntryData } from '../../logic';
import { getEntry } from 'astro:content';
import { CanonicalUrl } from '../../constants';
import { AstroSeo } from '@astrolib/seo';
import PagefindIndexer from '../../components/PagefindIndexer.astro';
import type { CollectionEntry } from 'astro:content';
import type { CellInfo, Series } from '../../types';
import { splitTextWithCellInfo } from '../../utils/ipynb';

type NotebookEntry = CollectionEntry<'notebooks'>;

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const notebooks: NotebookEntry[] = await getCollection('notebooks');
  return notebooks.map(notebook => ({
    params: { id: notebook.id }, props: { notebook },
  }));
}
// 2. For your template, you can get the entry directly from the prop
const { notebook } = Astro.props;
const notebookProps = await getRecursivelyEntryData(notebook);
// enrich the notebook with seealso special tags
if (notebookProps.seealso) {
  // notebookProps.seealso = seealso
  //load the seealso notebooks
  const seealsoNotebooksProps = []
  for (const seealso of notebookProps.seealso) {
    console.log('- seealso',seealso)
    const seealsoNotebook = await getEntry('notebooks',seealso)
    const seealsoProps = await getRecursivelyEntryData(seealsoNotebook)
    seealsoNotebooksProps.push(seealsoProps)
  }
  notebookProps.seealso = seealsoNotebooksProps

}

const cells: CellInfo[] = splitTextWithCellInfo(notebook.body ?? '')
const pagefindIndexerContent = cells.reduce((acc, cell) => {
  if(cell.cellType === "markdown") {
    return acc + '\n\n' + cell.content
  } else if (cell.cellType === "code") {
    return acc + '\n\n' + '```python\n' + cell.content + '\n```\n'
  } 
  return acc
}, '')


const allSeries = await getCollection("series");

const seriesMentioningThisTask:Partial<Series>[] = []
for(const seriesEntry of allSeries){
  if(seriesEntry.data.notebooks && seriesEntry.data.notebooks.some(t => t.id === notebook.id)){
    seriesMentioningThisTask.push({
      id: seriesEntry.id,
      title: seriesEntry.data.title
    })
  }
}

---



<Layout title={notebookProps.title}>
  <PagefindIndexer
    contentCollection="notebook"
    title={notebookProps.title} 
    content={pagefindIndexerContent} 
    series={seriesMentioningThisTask as Series[]}
  />
  <AstroSeo
    canonical={CanonicalUrl}
    title={notebookProps.title}
    description={notebookProps.description}
  />
  <NotebookModal client:only="react" 
    notebook={notebookProps}

    raw={notebook.body ?? ''} 
  />
</Layout>