---
import Layout from '../layouts/Layout.astro';
import TokenModal from '../components/TokenModal';
import { CanonicalUrl } from '../constants';
import { AstroSeo } from '@astrolib/seo';


const title = "Your API key - Impresso Datalab"
const description = "Log in and accept our Terms of Use to get your API key for the Impresso Datalab API and python library."
// https://docs.astro.build/en/guides/routing/#dynamic-redirects
---
<Layout title={title}>
  <AstroSeo
    canonical={CanonicalUrl}
    title={title}
    description={description} />
  <TokenModal client:only="react" />
</Layout>