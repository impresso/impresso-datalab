---
import Layout from "../../layouts/Layout.astro"
import PagefindIndexer from "../../components/PagefindIndexer.astro"
import TaskModal from "../../components/TaskModal"
import { getCollection } from "astro:content"
import { getRecursivelyEntryData, getTableOfContents } from "../../logic"
import { CanonicalUrl } from "../../constants"
import { AstroSeo } from "@astrolib/seo"
import type { Series, Task, TOCEntry } from "../../types"
import type { CollectionEntry } from 'astro:content';

type TaskEntry = CollectionEntry<'tasks'>;

export async function getStaticPaths() {
  const tasks = await getCollection("tasks")
  return tasks.map((task: TaskEntry) => ({
    params: { id: task.id },
    props: { task },
  }))
}

const { task } = Astro.props as { task: TaskEntry };

const taskProps: Task = await getRecursivelyEntryData(task)
const toc: TOCEntry[] = getTableOfContents(task.body || "")
const tags = taskProps.tags || []

const allSeries = await getCollection("series");

const seriesMentioningThisTask:Partial<Series>[] = []
for(const seriesEntry of allSeries){
  if(seriesEntry.data.tasks && seriesEntry.data.tasks.some(t => t.id === task.id)){
    seriesMentioningThisTask.push({
      id: seriesEntry.id,
      title: seriesEntry.data.title
    })
  }
}


---

<Layout title={taskProps.title}>
  <AstroSeo
    canonical={CanonicalUrl}
    title={taskProps.title}
    description={taskProps.summary || taskProps.title}
  />
  <PagefindIndexer
    contentCollection="task"
    title={taskProps.title} 
    content={task.body ?? ''} 
    tags={tags}
    series={seriesMentioningThisTask as Series[]}
  />
  <TaskModal
    client:only="react"
    task={taskProps}
    content={task.body}
    toc={toc}
  />
</Layout>
