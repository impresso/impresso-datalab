---
import { AstroSeo } from '@astrolib/seo';
import Layout from '../layouts/Layout.astro';
import { CanonicalUrl } from '../constants';
const title = 'Impresso Datalab';
const description = 'Explore and work programmatically with the Impresso Corpus, Data and Models. Join us in this early stage of development and help us to improve the platform!';
---

<Layout 
	title={title}
	description={description}
>
<AstroSeo
	title={title}
	description={description}
	canonical={CanonicalUrl}
/>
</Layout>
